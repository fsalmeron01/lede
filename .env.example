# App
NODE_ENV=production
APP_URL=http://localhost:3000
PORT=3000

# Database / Queue
POSTGRES_DB=transcriber
POSTGRES_USER=transcriber
POSTGRES_PASSWORD=change-me-now
DATABASE_URL=postgresql://transcriber:change-me-now@postgres:5432/transcriber
REDIS_URL=redis://redis:6379

# Storage
STORAGE_ROOT=/data
PUBLIC_DOWNLOAD_BASE_URL=http://localhost:3000

# Media / transcription
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
MAX_SOURCE_URL_LENGTH=2048

# Optional: tune yt-dlp behavior
YTDLP_FORMAT=bestaudio/best
